{
  "name": "simple-markdown-viewer",
  "version": "0.1.2",
  "description": "A small installable Markdown viewer with import, export, copy, and light/dark modes.",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer.js && node --check scripts/copy-portable-theme.js",
    "smoke": "electron . --smoke-test",
    "dist": "electron-builder --win && node scripts/copy-portable-theme.js"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-kr": "^5.2.9",
    "@highlightjs/cdn-assets": "^11.11.1",
    "dompurify": "^3.2.4",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.7"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.local.simplemarkdownviewer",
    "productName": "Simple Markdown Viewer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraFiles": [
      { "from": "theme.cfg", "to": "theme.cfg" }
    ],
    "extraResources": [
      { "from": "theme.cfg", "to": "theme.cfg" }
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico"
    },
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Viewer"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "author": "hyunwwww <153688878+hyunwwww@users.noreply.github.com>"
}
